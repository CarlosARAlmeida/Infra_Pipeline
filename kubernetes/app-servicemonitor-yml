apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: app-python-monitor
  namespace: observability
  labels:
    release: prometheus-stack # Crucial: deve bater com o nome do seu Helm release
spec:
  selector:
    matchLabels:
      app: app-python-carlos
  namespaceSelector:
    matchNames:
      - observability
  endpoints:
  - port: metrics
    interval: 15s
    path: /metrics